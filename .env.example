# Supabase — создайте проект на https://supabase.com
# Project URL и anon key берутся из: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Опционально: base path для деплоя на GitHub Pages (например /LogLife)
# BASE_PATH=/LogLife

# Опционально: ссылки в профиле (если не заданы — пункты скрыты)
# VITE_SUPPORT_AUTHOR_URL=https://ko-fi.com/yourname
# VITE_GITHUB_REPO_URL=https://github.com/you/log-life
